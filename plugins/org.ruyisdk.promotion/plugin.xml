<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

    <extension point="org.eclipse.ui.menus">
        <menuContribution
            locationURI="menu:org.ruyisdk.ruyi.menus.main?after=additions">
            <command
                commandId="org.eclipse.ui.views.showView"
                label="RuyiSDK Website"
                tooltip="Open RuyiSDK website for login">
                <parameter
                    name="org.eclipse.ui.views.showView.viewId"
                    value="org.ruyisdk.promotion.view" />
            </command>
        </menuContribution>
    </extension>
    <extension
        point="org.eclipse.ui.views">
        <category
            id="org.ruyisdk.promotion.category"
            name="RuyiSDK"/>
        <view
            id="org.ruyisdk.promotion.view"
            name="RuyiSDK Website"
            class="org.ruyisdk.promotion.views.WebsiteView"
            category="org.ruyisdk.promotion.category"/>
    </extension>
</plugin>
